<turbo-frame id="shuffle-recipe">
  <% if @shuffle.voting_complete? %>
  <div  class="p-4 border border-gray-300 rounded-lg bg-gray-50 dark:border-gray-600 dark:bg-gray-800 max-w-2xl mx-auto my-6" role="alert">
    <div class="flex items-center">
      <svg class="shrink-0 w-4 h-4 me-2 dark:text-gray-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"></path>
      </svg>
      <span class="sr-only">Info</span>
      <h3 class="text-lg font-medium text-gray-800 dark:text-gray-300">Voting Complete</h3>
    </div>
    <div class="mt-2 mb-4 text-sm text-gray-800 dark:text-gray-300">
      You have successfully completed the voting process for this shuffle. You can view your results below.
      <br>
      You can retreive your results using this code: <%= shuffle.share_token %>
    </div>
  </div>
  <% else %>
    <%= tag.div class: "grid grid-cols-[max-content_1fr_max-content] mt-16 mx-auto max-w-3xl" do %>
      <div class="flex justify-center h-full peer/left hover:bg-red-50 hover:dark:bg-red-800 rounded-xl bg-gray-50 dark:bg-gray-800 dark:border-gray-700 px-6">
        <div class="self-center">
          <%= button_to shuffle_shuffle_recipe_path(shuffle, shuffle_recipe, status: :rejected), method: :patch, class: "text-red-700 border border-red-700 bg-red-700 hover:text-white focus:ring-4 focus:outline-none focus:ring-red-300 font-medium rounded-full text-sm p-2.5 text-center inline-flex items-center dark:border-red-500 dark:text-red-500 dark:hover:text-white dark:focus:ring-red-800 dark:bg-red-500 self-center" do %>
            <%= image_tag('thumbs-down.svg', class: 'size-12') %>
          <% end %>
        </div>
      </div>
      <div class="flex justify-center h-full peer/right hover:bg-green-50 hover:dark:bg-green-800 order-3 bg-gray-50 rounded-xl dark:bg-gray-800 dark:border-gray-700 px-6">
        <div class="self-center">
          <%= button_to shuffle_shuffle_recipe_path(shuffle, shuffle_recipe, status: :accepted), method: :patch, class: "text-green-700 border border-green-700 bg-green-700 hover:text-white focus:ring-4 focus:outline-none focus:ring-green-300 font-medium rounded-full text-sm p-2.5 text-center inline-flex items-center dark:border-green-500 dark:text-green-500 dark:focus:ring-green-800 dark:bg-green-500" do %>
            <%= image_tag('thumbs-up.svg', class: 'size-12') %>
          <% end %>
        </div>
      </div>
      <div class="flex justify-center transition-transform duration-300 ease-in-out peer-hover/right:rotate-6 peer-hover/left:-rotate-6 px-16 ">
        <div class="max-w-sm bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700">
          <%= image_tag recipe.image.attached? ? url_for(recipe.image) : "https://placehold.co/600x400", class: "rounded-t-lg" %>
          <div class="p-5">
            <%= tag.h5 recipe.name, class: "mb-2 text-xl font-bold tracking-tight text-gray-900 dark:text-white" %>
            <div class="flex flex-col gap-2 my-4">
              <div class="flex justify-between">
                <p class="text-sm text-gray-700 font-bold dark:text-white">Protein</p>
                <div class="flex flex-wrap content-end">
                  <%= tag.p recipe.traits.select { |x| x.category == 'protein' }.pluck(:name).join(', '), class: "text-sm text-gray-700 dark:text-white" %>
                </div>
              </div>

              <div class="flex justify-between">
                <p class="text-sm text-gray-700 font-bold dark:text-white">Carb</p>
                <div class="flex flex-wrap content-end">
                  <% if recipe.carbohydrates.empty? %>
                    <%= tag.p "None", class: "text-sm text-gray-700 dark:text-white" %>
                  <% else %>
                    <%= tag.p recipe.traits.select { |x| x.category == 'carbohydrate' }.pluck(:name).join(', '), class: "text-sm text-gray-700 dark:text-white" %>
                  <% end %>
                </div>
              </div>

              <div class="flex justify-between">
                <p class="text-sm text-gray-700 font-bold dark:text-white">Cuisine</p>
                <div class="flex flex-wrap content-end">
                  <%= tag.p recipe.traits.select { |x| x.category == 'cuisine' }.pluck(:name).join(', '), class: "text-sm text-gray-700 dark:text-white" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="flex mx-auto w-1/3 justify-center">
      <%= button_to "Skip", shuffle_shuffle_recipe_path(shuffle, shuffle_recipe, status: 'skipped'), method: :patch, class: "py-2.5 px-5 me-2 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-100 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700 my-6" %>
    </div>
  <% end %>
</turbo-frame>
