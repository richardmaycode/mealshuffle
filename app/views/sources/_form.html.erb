<%= form_with(model: [@recipe, @source]) do |form| %>
  <%= tag.div class: "w-1/2 mx-auto p-6 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-700 dark:border-gray-700 mt-6" do %>
    <div class="flex flex-col gap-4">
      <div>
        <%= form.label :creator_id, "Creator", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
        <%= form.select :creator_id, options_for_select(Creator.all.map { |creator| [creator.display_name, creator.id] }, {} ), { }, class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 appearance-none" %>
      </div>

      <div>
        <%= form.label :url, "Direct Link", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
        <%= form.text_field :url, class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
        <p id="helper-text-explanation" class="mt-2 text-sm text-gray-500 dark:text-gray-400">This should be a link to a video or post describing the recipe.</p>
      </div>

      <div>
        <%= form.label :note, "Notes", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
        <%= form.text_area :note, rows: 4, placeholder: "Anything else we should know?", class: "block p-2.5 w-full text-sm text-gray-900 bg-gray-50 rounded-lg border border-gray-300 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
      </div>

      <div>
        <%= form.submit class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 me-2 mb-2 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800" %>

        <%= link_to "Cancel", recipe_path(@recipe), class: "text-white bg-red-700 hover:bg-red-800 focus:ring-4 focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 me-2 mb-2 dark:bg-red-600 dark:hover:bg-red-700 focus:outline-none dark:focus:ring-red-800" %>
      </div>
    </div>
  <% end %>
<% end %>
