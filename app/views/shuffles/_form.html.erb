<%= form_with(model: @shuffle) do |form| %>
  <%= tag.div class: "flex flex-col max-w-3xl mx-auto p-6 mb-6 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700" do %>
    <%= tag.div class: "my-2" do %>
      <%= form.label :meal_ids, 'Meal Types', class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <div class="grid grid-cols-3 gap-4">
        <%= form.collection_checkboxes :meal_ids, @available_traits.select { |trait| trait.meal? }, :id, :name do |meal_choice| %>
          <div class="flex items-center ps-4 border border-gray-200 rounded-sm dark:border-gray-700 px-4">
            <%= meal_choice.check_box class: "w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded-sm focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600" %>
            <%= meal_choice.label class: "w-full py-4 ms-2 text-sm font-medium text-gray-900 dark:text-gray-300" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= tag.div class: "my-2" do %>
      <%= form.label :protein_ids, 'Protein Types', class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <div class="grid grid-cols-3 gap-4">
        <%= form.collection_checkboxes :protein_ids, @available_traits.select { |trait| trait.protein? }, :id, :name do |protein_choice| %>
          <div class="flex items-center ps-4 border border-gray-200 rounded-sm dark:border-gray-700 px-4">
            <%= protein_choice.check_box class: "w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded-sm focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600" %>
            <%= protein_choice.label class: "w-full py-4 ms-2 text-sm font-medium text-gray-900 dark:text-gray-300" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= tag.div class: "my-2" do %>
      <%= form.label :cuisine_ids, 'Cuisine Types', class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
      <div class="grid grid-cols-3 gap-4">
        <%= form.collection_checkboxes :cuisine_ids, @available_traits.select { |trait| trait.cuisine? }, :id, :name do |cuisine_choice| %>
          <div class="flex items-center ps-4 border border-gray-200 rounded-sm dark:border-gray-700 px-4">
            <%= cuisine_choice.check_box class: "w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded-sm focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600" %>
            <%= cuisine_choice.label class: "w-full py-4 ms-2 text-sm font-medium text-gray-900 dark:text-gray-300" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= tag.div class: "mt-6 mb-2" do %>

      <div class="flex">
          <div class="flex items-center h-5">
            <%= form.check_box :saved_recipes, class: "w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded-sm focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600", aria_describedby: "helper-checkbox-text", disabled: @current_user.nil? %>
          </div>
          <div class="ms-2 text-sm">
              <%= form.label :saved_recipes, "Saved Recipes Only", class: "font-medium text-gray-900 dark:text-gray-300" %>

              <p id="helper-checkbox-text" class="text-xs font-normal text-gray-500 dark:text-gray-300">Users with an account, can favorite recipes and shuffle only their favorites.</p>
          </div>
      </div>
      <% end %>
  <% end %>
  <%= tag.div class: "flex gap-4 max-w-3xl mx-auto p-6 mb-12 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700" do %>
    <%= form.submit class: "flex-grow text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
    <%= link_to 'Cancel', shuffles_path, class: "focus:outline-none text-white bg-red-700 hover:bg-red-800 focus:ring-4 focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-900" %>
  <% end %>
<% end %>
