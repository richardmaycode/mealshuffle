<div class="flex flex-col gap-2">
  <div class="flex justify-between ">
    <h1 class="mb-4 text-4xl font-extrabold leading-none tracking-tight text-gray-900 md:text-5xl lg:text-6xl dark:text-white"><%= title %></h1>
    <div class="content-center">
      <%= link_to link_text, link, class: 'py-2.5 px-5 me-2 mb-2 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-100 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700' %>
    </div>
  </div>
  <div>
    <%= tag.p local_assigns[:body_text], class: "mb-4 text-lg font-normal text-gray-500 dark:text-gray-400" if local_assigns[:body_text].present? %>
  </div>
</div>
